# 复制此文件为 .env.local 并填入你的 API Key

# OpenAI API Key（用于 embedding 和 chat completion）
OPENAI_API_KEY=sk-xxx

# OpenAI 兼容 API 的基础地址，必须是 API 路径而不是服务商网页地址
# 例如 https://api.openai.com/v1
# OPENAI_BASE_URL=https://api.openai.com/v1

# 可选：聊天模型名称。第三方服务商请填写其已开通的模型，例如 gpt-5.4-mini。
# OPENAI_CHAT_MODEL=gpt-4o-mini

# 可选：启用 Agent 的 Tavily 联网搜索。仅配置在服务端环境变量，不要以 NEXT_PUBLIC_ 前缀暴露。
# TAVILY_API_KEY=tvly-xxx
